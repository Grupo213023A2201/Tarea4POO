from abc import ABC, abstractmethod
import datetime

# ==========================
# LOGS
# ==========================
def registrar_log(mensaje):
    with open("logs.txt", "a") as archivo:
        archivo.write(f"{datetime.datetime.now()} - {mensaje}\n")


# ==========================
# EXCEPCIONES PERSONALIZADAS
# ==========================
class ClienteError(Exception):
    pass

class ServicioError(Exception):
    pass

class ReservaError(Exception):
    pass


# ==========================
# CLASE ABSTRACTA
# ==========================
class Entidad(ABC):
    def __init__(self, nombre):
        self._nombre = nombre

    @abstractmethod
    def mostrar_info(self):
        pass


# ==========================
# CLIENTE
# ==========================
class Cliente(Entidad):
    def __init__(self, nombre, documento, email):
        super().__init__(nombre)
        self.__documento = documento
        self.__email = email

    def mostrar_info(self):
        return f"Cliente: {self._nombre} - Documento: {self.__documento}"

    def validar(self):
        if not self._nombre.replace(" ", "").isalpha():
            raise ClienteError("Nombre inválido")
        if len(self.__documento) < 5:
            raise ClienteError("Documento inválido")
        if "@" not in self.__email:
            raise ClienteError("Email inválido")

    def get_documento(self):
        return self.__documento


# ==========================
# SERVICIO ABSTRACTO
# ==========================
class Servicio(ABC):
    def __init__(self, nombre, precio_base):
        self.nombre = nombre
        self.precio_base = precio_base

    @abstractmethod
    def calcular_costo(self, tiempo, impuesto=0, descuento=0):
        pass


# ==========================
# SERVICIOS (HERENCIA + POLIMORFISMO)
# ==========================
class Sala(Servicio):
    def calcular_costo(self, tiempo, impuesto=0, descuento=0):
        base = self.precio_base * tiempo
        return base + (base * impuesto) - descuento


class Equipo(Servicio):
    def calcular_costo(self, tiempo, impuesto=0, descuento=0):
        base = self.precio_base * tiempo
        return base + (base * impuesto) - descuento


class Asesoria(Servicio):
    def calcular_costo(self, tiempo, impuesto=0, descuento=0):
        base = self.precio_base * tiempo * 1.2
        return base + (base * impuesto) - descuento


# ==========================
# RESERVA
# ==========================
class Reserva:
    def __init__(self, cliente, servicio, duracion):
        self.cliente = cliente
        self.servicio = servicio
        self.duracion = duracion
        self.estado = "Pendiente"

def procesar(self):
    try:
        self.cliente.validar()
        costo = self.servicio.calcular_costo(self.duracion, impuesto=0.19, descuento=10)
        self.estado = "Confirmada"
        return f"Reserva confirmada. Costo final: ${costo}"

    except Exception as e:
        registrar_log(str(e))
        self.estado = "Error"
        raise ReservaError("Fallo al procesar reserva") from e

    finally:
        registrar_log(f"Reserva procesada con estado: {self.estado}")

    def cancelar(self):
        self.estado = "Cancelada"
        return "Reserva cancelada"


# ==========================
# SISTEMA
# ==========================
class Sistema:
    def __init__(self):
        self.clientes = []
        self.reservas = []

    def agregar_cliente(self, cliente):
        try:
            cliente.validar()
            self.clientes.append(cliente)
        except ClienteError as e:
            registrar_log(str(e))

    def crear_reserva(self, cliente, servicio, duracion):
        try:
            reserva = Reserva(cliente, servicio, duracion)
            resultado = reserva.confirmar()
            self.reservas.append(reserva)
            print(resultado)

        except Exception as e:
            registrar_log(str(e))


